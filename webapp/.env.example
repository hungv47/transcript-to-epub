# Copy to .env and fill in. All optional — the app runs without any of these
# (in intent-capture mode, with no live payments).

# Absolute public origin, used for Polar redirect URLs.
PUBLIC_URL=http://localhost:8000

# Force HTTP requests to HTTPS in production. Defaults on when PUBLIC_URL is https.
FORCE_HTTPS=

# --- Polar (leave blank to run in intent-capture mode) ---
POLAR_ACCESS_TOKEN=
# Monthly product (required to enable payments).
POLAR_PRODUCT_ID=
# Annual product (optional). When set, checkout offers both monthly + annual
# and either product satisfies webhook/checkout validation.
POLAR_PRODUCT_ID_ANNUAL=
POLAR_WEBHOOK_SECRET=
# production or sandbox
POLAR_SERVER=production

# Creator plan prices shown in the app, in the smallest currency unit.
PLAN_PRICE_CENTS=700
PLAN_PRICE_ANNUAL_CENTS=6700
CURRENCY=usd

# Local demo only: fulfill the paid edition WITHOUT charging. Never set in prod.
ALLOW_FREE_UNLOCK=

# Where job folders are written.
T2B_JOBS_DIR=

# Guardrails.
MAX_TRANSCRIPT_CHARS=800000
MAX_UPLOAD_BYTES=8388608
