# Copy to .env and fill in. All optional — the app runs without any of these
# (in intent-capture mode, with no live payments).

# Absolute public origin, used for Stripe redirect URLs.
PUBLIC_URL=http://localhost:8000

# --- Stripe (leave blank to run in intent-capture mode) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Price of a single-book unlock, in the smallest currency unit (900 = $9.00).
UNLOCK_PRICE_CENTS=900
CURRENCY=usd

# Local demo only: fulfill the paid edition WITHOUT charging. Never set in prod.
ALLOW_FREE_UNLOCK=

# Where job folders are written.
T2B_JOBS_DIR=

# Guardrails.
MAX_TRANSCRIPT_CHARS=800000
MAX_UPLOAD_BYTES=8388608
